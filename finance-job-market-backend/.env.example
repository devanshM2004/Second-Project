# Copy this file to `.env` and fill in real values.
# The app works without a BLS_API_KEY, but registered keys get higher rate limits.

APP_NAME=finance-job-market-backend
APP_ENV=development

# BLS Public Data API v2 endpoint
BLS_API_URL=https://api.bls.gov/publicAPI/v2/timeseries/data/

# Optional: register at https://data.bls.gov/registrationEngine/ to get a key
BLS_API_KEY=
